        -- LÓGICA DO SELETOR: Conversão de Valores e Interação Física (Mobile e PC)
        local function updateColorOutputs(color)
            colorPreview.BackgroundColor3 = color
            
            -- Saída HEX
            local hexStr = string_format("#%02X%02X%02X", math_floor(color.R * 255), math_floor(color.G * 255), math_floor(color.B * 255))
            if hexBox.Text ~= hexStr then hexBox.Text = hexStr end
            
            -- Saída RGB
            local rgbStr = string_format("%d, %d, %d", math_floor(color.R * 255), math_floor(color.G * 255), math_floor(color.B * 255))
            if rgbBox.Text ~= rgbStr then rgbBox.Text = rgbStr end

            -- Dispara o callback dinâmico ativo em tempo real
            if pickerActiveCallback then
                pcall(pickerActiveCallback, color)
            end
        end

        local function updateHSV()
            local selectedColor = Color3.fromHSV(pickerCurrentH, pickerCurrentS, pickerCurrentV)
            satValCanvas.BackgroundColor3 = Color3.fromHSV(pickerCurrentH, 1, 1)
            updateColorOutputs(selectedColor)
        end

        -- Interação no Canvas Saturation-Value
        local isTrackingCanvas = false
        local function processCanvasInput(input)
            local canvasPos = satValCanvas.AbsolutePosition
            local canvasSize = satValCanvas.AbsoluteSize
            local relativeX = math_clamp(input.Position.X - canvasPos.X, 0, canvasSize.X)
            local relativeY = math_clamp(input.Position.Y - canvasPos.Y, 0, canvasSize.Y)

            pickerCurrentS = relativeX / canvasSize.X
            pickerCurrentV = 1 - (relativeY / canvasSize.Y)

            canvasCursor.Position = UDim2_new(pickerCurrentS, 0, 1 - pickerCurrentV, 0)
            updateHSV()
        end

        satValCanvas.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                isTrackingCanvas = true
                processCanvasInput(input)
            end
        end)

        -- Interação no Slider de Tonalidade (Hue)
        local isTrackingHue = false
        local function processHueInput(input)
            local sliderPos = hueSlider.AbsolutePosition
            local sliderSize = hueSlider.AbsoluteSize
            local relativeY = math_clamp(input.Position.Y - sliderPos.Y, 0, sliderSize.Y)

            pickerCurrentH = 1 - (relativeY / sliderSize.Y)

            hueCursor.Position = UDim2_new(0, -2, 1 - pickerCurrentH, 0)
            updateHSV()
        end

        hueSlider.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                isTrackingHue = true
                processHueInput(input)
            end
        end)

        -- Conexão global para rastrear arraste do dedo ou mouse fora dos limites físicos do botão
        UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                if isTrackingCanvas then
                    processCanvasInput(input)
                elseif isTrackingHue then
                    processHueInput(input)
                end
            end
        end)

        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                isTrackingCanvas = false
                isTrackingHue = false
            end
        end)

        -- Escuta de entradas textuais HEX manuais
        hexBox.FocusLost:Connect(function(enterPressed)
            local text = hexBox.Text:gsub("#", "")
            if #text == 6 then
                local r = tonumber(text:sub(1, 2), 16)
                local g = tonumber(text:sub(3, 4), 16)
                local b = tonumber(text:sub(5, 6), 16)
                if r and g and b then
                    local targetColor = Color3_fromRGB(r, g, b)
                    pickerCurrentH, pickerCurrentS, pickerCurrentV = targetColor:ToHSV()
                    canvasCursor.Position = UDim2_new(pickerCurrentS, 0, 1 - pickerCurrentV, 0)
                    hueCursor.Position = UDim2_new(0, -2, 1 - pickerCurrentH, 0)
                    updateHSV()
                end
            end
        end)

        -- Escuta de entradas textuais RGB manuais
        rgbBox.FocusLost:Connect(function(enterPressed)
            local parts = {}
            for token in rgbBox.Text:gmatch("[^,%s]+") do
                table_insert(parts, tonumber(token))
            end
            if #parts == 3 then
                local r = math_clamp(parts[1] or 0, 0, 255)
                local g = math_clamp(parts[2] or 0, 0, 255)
                local b = math_clamp(parts[3] or 0, 0, 255)
                local targetColor = Color3_fromRGB(r, g, b)
                pickerCurrentH, pickerCurrentS, pickerCurrentV = targetColor:ToHSV()
                canvasCursor.Position = UDim2_new(pickerCurrentS, 0, 1 - pickerCurrentV, 0)
                hueCursor.Position = UDim2_new(0, -2, 1 - pickerCurrentH, 0)
                updateHSV()
            end
        end)

        ColorPickerUI.Parent = targetParent
    end

    -- Função mestre para invocar o Seletor de Cores Standalone
    local function openCustomColorPicker(title, defaultColor, callback)
        createCustomColorPicker()
        if not ColorPickerUI then return end

        local mainFrame = ColorPickerUI:FindFirstChild("MainFrame")
        if mainFrame then
            local titleLabel = mainFrame:FindFirstChild("TextLabel")
            if titleLabel then titleLabel.Text = tostring(title) end

            local canvas = mainFrame:FindFirstChild("Frame")
            local hueSlider = mainFrame:FindFirstChild("HueSlider")
            local canvasCursor = canvas and canvas:FindFirstChild("Frame")
            local hueCursor = hueSlider and hueSlider:FindFirstChild("Frame")

            pickerCurrentH, pickerCurrentS, pickerCurrentV = defaultColor:ToHSV()
            pickerActiveCallback = callback

            -- Reposiciona cursores de forma visual baseada nos novos dados
            if canvasCursor then
                canvasCursor.Position = UDim2_new(pickerCurrentS, 0, 1 - pickerCurrentV, 0)
            end
            if hueCursor then
                hueCursor.Position = UDim2_new(0, -2, 1 - pickerCurrentH, 0)
            end

            if canvas then
                canvas.BackgroundColor3 = Color3.fromHSV(pickerCurrentH, 1, 1)
            end

            -- Atualiza o preview e saídas textuais imediatamente
            local colorPreview = mainFrame:FindFirstChild("ColorPreview")
            if colorPreview then colorPreview.BackgroundColor3 = defaultColor end

            local hexBox = mainFrame:FindFirstChild("TextBox") -- HexBox
            local hexStr = string_format("#%02X%02X%02X", math_floor(defaultColor.R * 255), math_floor(defaultColor.G * 255), math_floor(defaultColor.B * 255))
            if hexBox then hexBox.Text = hexStr end

            local rgbBox = mainFrame:FindFirstChild("TextBox", true) -- RGBBox (segunda caixa de texto)
            local rgbStr = string_format("%d, %d, %d", math_floor(defaultColor.R * 255), math_floor(defaultColor.G * 255), math_floor(defaultColor.B * 255))
            if rgbBox then rgbBox.Text = rgbStr end
        end

        ColorPickerUI.Enabled = true
    end

    -- =========================================================================
    -- CONFIGURAÇÃO DE ORIENTAÇÃO DO LIFE TIMER
    -- =========================================================================
    local function getLifeTargetPart(char, origin)
        if not char then return nil, Vector3_new(0, 0, 0) end
        if origin == "Head" then
            return char:FindFirstChild("Head"), Vector3_new(0, 3, 0)
        elseif origin == "Torso" then
            local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso") or char:FindFirstChild("HumanoidRootPart")
            return torso, Vector3_new(0, 3, 0)
        else -- Inferior
            local hrp = char:FindFirstChild("HumanoidRootPart")
            return hrp, Vector3_new(0, -3.2, 0)
        end
    end

