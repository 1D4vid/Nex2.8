    -- PAINEL ESQUERDO (Aparência, Viewport & Equipados)
    -- =================================================================
    local LeftPanel = Instance_new("Frame")
    LeftPanel.Size = UDim2.new(0.32, 0, 1, 0)
    LeftPanel.Position = UDim2.new(0, 0, 0, 0)
    LeftPanel.BackgroundTransparency = 1
    LeftPanel.Parent = MainFrame

    -- Viewport para renderizar o personagem
    local Viewport = Instance_new("ViewportFrame")
