    CatalogGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    
    -- Tenta colocar na CoreGui para evitar ser deletado, se não conseguir vai para PlayerGui
    local success, coregui = pcall(function() return game:GetService("CoreGui") end)
    CatalogGui.Parent = success and coregui or LocalPlayer:WaitForChild("PlayerGui")

    -- Janela Principal (Main Frame)
    local MainFrame = Instance_new("Frame")
    MainFrame.Size = UDim2.new(0, 900, 0, 500)
    MainFrame.Position = UDim2.new(0.5, -450, 0.5, -250)
    MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    MainFrame.BorderSizePixel = 0
    MainFrame.Parent = CatalogGui

    local MainCorner = Instance_new("UICorner", MainFrame)
    MainCorner.CornerRadius = UDim.new(0, 12)

    local MainStroke = Instance_new("UIStroke", MainFrame)
    MainStroke.Color = Color3.fromRGB(45, 45, 45)
    MainStroke.Thickness = 1.5

