    -- Botões de Controle rápidos abaixo do Viewport
    local ControlContainer = Instance_new("Frame")
    ControlContainer.Size = UDim2.new(0.9, 0, 0.1, 0)
    ControlContainer.Position = UDim2.new(0.05, 0, 0.67, 0)
    ControlContainer.BackgroundTransparency = 1
    ControlContainer.Parent = LeftPanel

    local ControlLayout = Instance_new("UIListLayout")
    ControlLayout.FillDirection = Enum.FillDirection.Horizontal
    ControlLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    ControlLayout.Padding = UDim.new(0, 10)
    ControlLayout.Parent = ControlContainer

    local function CreateControlButton(icon, callback)
        local btn = Instance_new("ImageButton")
        btn.Size = UDim2.new(0, 40, 0, 40)
        btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        btn.Image = icon
        btn.ImageColor3 = Color3.fromRGB(255, 255, 255)
        btn.Parent = ControlContainer
        Instance_new("UICorner", btn).CornerRadius = UDim.new(0, 6)
        
        btn.MouseButton1Click:Connect(callback)
        return btn
    end

    -- Botão Limpar Visual (Lixeira)
    local ClearBtn = CreateControlButton("rbxassetid://10817036640", function()
        local char = LocalPlayer.Character
        if char then
            for _, item in ipairs(char:GetChildren()) do
                if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") then
                    item:Destroy()
                end
            end
            SendNotification("Visual limpo!", 2)
        end
    end)

    -- Botão Atualizar (Refresh)
    local RefreshBtn = CreateControlButton("rbxassetid://10613271168", function()
        -- Atualiza ou recarrega o personagem
        LocalPlayer:LoadCharacter()
    end)

    -- Lista Horizontal de Equipados na parte inferior
    local EquippedScroll = Instance_new("ScrollingFrame")
    EquippedScroll.Size = UDim2.new(0.9, 0, 0.18, 0)
    EquippedScroll.Position = UDim2.new(0.05, 0, 0.79, 0)
    EquippedScroll.BackgroundTransparency = 1
    EquippedScroll.CanvasSize = UDim2.new(2, 0, 0, 0) -- Rolagem horizontal
    EquippedScroll.ScrollBarThickness = 4
    EquippedScroll.Parent = LeftPanel

    local EquippedLayout = Instance_new("UIListLayout")
    EquippedLayout.FillDirection = Enum.FillDirection.Horizontal
    EquippedLayout.Padding = UDim.new(0, 6)
    EquippedLayout.Parent = EquippedScroll

    -- =================================================================
    -- PAINEL DIREITO (Navegação do Catálogo)
    -- =================================================================
    local RightPanel = Instance_new("Frame")
    RightPanel.Size = UDim2.new(0.68, -15, 1, 0)
    RightPanel.Position = UDim2.new(0.32, 0, 0, 0)
    RightPanel.BackgroundTransparency = 1
    RightPanel.Parent = MainFrame

    -- Barra Superior (Pesquisa e Abas)
    local TopBar = Instance_new("Frame")
    TopBar.Size = UDim2.new(1, 0, 0, 70)
    TopBar.BackgroundTransparency = 1
    TopBar.Parent = RightPanel

    local SearchBox = Instance_new("TextBox")
    SearchBox.Size = UDim2.new(0.4, 0, 0, 32)
    SearchBox.Position = UDim2.new(0, 10, 0, 15)
    SearchBox.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    SearchBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    SearchBox.PlaceholderText = "Pesquisar item..."
    SearchBox.Font = Enum.Font.SourceSans
    SearchBox.TextSize = 14
    SearchBox.Parent = TopBar
    Instance_new("UICorner", SearchBox).CornerRadius = UDim.new(0, 6)

    -- Contêiner de Categorias (Acessórios, Roupas, Cabelos, Rostos)
    local CategoryScroll = Instance_new("ScrollingFrame")
    CategoryScroll.Size = UDim2.new(0.55, 0, 0, 32)
    CategoryScroll.Position = UDim2.new(0.45, 0, 0, 15)
    CategoryScroll.BackgroundTransparency = 1
    CategoryScroll.CanvasSize = UDim2.new(1.5, 0, 0, 0)
    CategoryScroll.ScrollBarThickness = 0
    CategoryScroll.Parent = TopBar

    local CatLayout = Instance_new("UIListLayout")
    CatLayout.FillDirection = Enum.FillDirection.Horizontal
    CatLayout.Padding = UDim.new(0, 10)
    CatLayout.Parent = CategoryScroll

    -- Grid de Itens do Catálogo (ScrollingFrame)
    local CatalogScroll = Instance_new("ScrollingFrame")
    CatalogScroll.Size = UDim2.new(1, -20, 0.72, -10)
    CatalogScroll.Position = UDim2.new(0, 10, 0, 80)
    CatalogScroll.BackgroundTransparency = 1
    CatalogScroll.ScrollBarThickness = 6
    CatalogScroll.CanvasSize = UDim2.new(0, 0, 3, 0)
    CatalogScroll.Parent = RightPanel

    local Grid = Instance_new("UIGridLayout")
    Grid.CellSize = UDim2.new(0.23, -5, 0, 130)
    Grid.CellPadding = UDim2.new(0, 8, 0, 8)
    Grid.Parent = CatalogScroll

    -- Barra Inferior (Inserir Link / ID do item diretamente)
    local BottomBar = Instance_new("Frame")
    BottomBar.Size = UDim2.new(1, -20, 0.1, 0)
    BottomBar.Position = UDim2.new(0, 10, 0.88, 0)
    BottomBar.BackgroundTransparency = 1
    BottomBar.Parent = RightPanel

    local LinkInputBox = Instance_new("TextBox")
    LinkInputBox.Size = UDim2.new(0.8, 0, 0, 32)
    LinkInputBox.Position = UDim2.new(0, 0, 0.5, -16)
    LinkInputBox.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    LinkInputBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    LinkInputBox.PlaceholderText = "Insira o ID ou Link do Item aqui..."
    LinkInputBox.Font = Enum.Font.SourceSans
    LinkInputBox.TextSize = 13
    LinkInputBox.Parent = BottomBar
    Instance_new("UICorner", LinkInputBox).CornerRadius = UDim.new(0, 6)

    local EquipLinkBtn = Instance_new("TextButton")
    EquipLinkBtn.Size = UDim2.new(0.18, 0, 0, 32)
    EquipLinkBtn.Position = UDim2.new(0.82, 0, 0.5, -16)
    EquipLinkBtn.BackgroundColor3 = Theme.Accent
    EquipLinkBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
    EquipLinkBtn.Text = "Equipar"
    EquipLinkBtn.Font = Enum.Font.SourceSansBold
    EquipLinkBtn.TextSize = 14
    EquipLinkBtn.Parent = BottomBar
    Instance_new("UICorner", EquipLinkBtn).CornerRadius = UDim.new(0, 6)

    -- Botão de Fechar Interface (Canto superior direito)
    local CloseBtn = Instance_new("ImageButton")
    CloseBtn.Size = UDim2.new(0, 24, 0, 24)
    CloseBtn.Position = UDim2.new(1, -30, 0, 8)
    CloseBtn.BackgroundTransparency = 1
    CloseBtn.Image = "rbxassetid://10613271168" -- Ícone de fechar "X"
    CloseBtn.ImageColor3 = Color3.fromRGB(200, 200, 200)
    CloseBtn.Parent = MainFrame

    CloseBtn.MouseButton1Click:Connect(function()
        CatalogGui:Destroy()
    end)

    -- =================================================================
    -- FUNÇÕES DE LÓGICA E CONEXÕES
    -- =================================================================

    -- Atualiza a lista visual inferior de itens equipados
    local function UpdateEquippedList()
        -- Limpa a lista existente
        for _, v in ipairs(EquippedScroll:GetChildren()) do
            if v:IsA("ImageLabel") then v:Destroy() end
        end

        local char = LocalPlayer.Character
        if not char then return end

        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Accessory") then
                local iconId = "rbxthumb://type=Asset&id=" .. tostring(item:GetAttribute("AssetId") or 0) .. "&w=150&h=150"
                
                local img = Instance_new("ImageLabel")
                img.Size = UDim2.new(0, 42, 0, 42)
                img.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
                img.Image = iconId
                img.Parent = EquippedScroll
                Instance_new("UICorner", img).CornerRadius = UDim.new(0, 6)
            end
        end
    end

    -- Criação de um item listado no Catálogo (Grade Direita)
    local function AddCatalogItem(name, id, price)
        local Card = Instance_new("TextButton")
        Card.Text = ""
        Card.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        Card.Parent = CatalogScroll
        Instance_new("UICorner", Card).CornerRadius = UDim.new(0, 6)

        local Stroke = Instance_new("UIStroke", Card)
        Stroke.Color = Color3.fromRGB(45, 45, 45)

        local Thumbnail = Instance_new("ImageLabel")
        Thumbnail.Size = UDim2.new(0.9, 0, 0.6, 0)
        Thumbnail.Position = UDim2.new(0.05, 0, 0.05, 0)
        Thumbnail.BackgroundTransparency = 1
        Thumbnail.Image = "rbxthumb://type=Asset&id=" .. tostring(id) .. "&w=150&h=150"
        Thumbnail.Parent = Card

        local Title = Instance_new("TextLabel")
        Title.Size = UDim2.new(0.9, 0, 0.2, 0)
        Title.Position = UDim2.new(0.05, 0, 0.65, 0)
        Title.BackgroundTransparency = 1
        Title.Text = name
        Title.TextColor3 = Theme.Text
        Title.Font = Enum.Font.SourceSansBold
        Title.TextSize = 11
        Title.TextXAlignment = Enum.TextXAlignment.Left
        Title.Parent = Card

        local PriceLabel = Instance_new("TextLabel")
        PriceLabel.Size = UDim2.new(0.9, 0, 0.1, 0)
        PriceLabel.Position = UDim2.new(0.05, 0, 0.85, 0)
        PriceLabel.BackgroundTransparency = 1
        PriceLabel.Text = "R$ " .. tostring(price)
        PriceLabel.TextColor3 = Theme.TextDark
        PriceLabel.Font = Enum.Font.SourceSans
        PriceLabel.TextSize = 10
        PriceLabel.TextXAlignment = Enum.TextXAlignment.Left
        PriceLabel.Parent = Card

        Card.MouseButton1Click:Connect(function()
            local assetId = tonumber(id)
            if assetId then
                -- Define os atributos que a função usa
                selectedModalId = assetId
                currentModalAction = "Accessory"
                PTitle.Text = "EQUIPAR ITEM"
                PName.Text = name
                PApplyBtn.Text = "Equip"
                PImage.Image = "rbxthumb://type=Asset&id=" .. assetId .. "&w=150&h=150"
                
                ModalOverlay.Visible = true
                PreviewBox.Visible = true
            end
        end)
    end

    -- Criação dos botões de filtro de Categorias na barra superior
    local function AddCategoryTab(name)
        local Tab = Instance_new("TextButton")
        Tab.Size = UDim2.new(0, 80, 1, 0)
        Tab.BackgroundTransparency = 1
        Tab.Text = name
        Tab.TextColor3 = Theme.TextDark
        Tab.Font = Enum.Font.SourceSansBold
        Tab.TextSize = 13
        Tab.Parent = CategoryScroll

        Tab.MouseButton1Click:Connect(function()
            -- Lógica para mudar de aba/categoria de itens futuramente
        end)
    end

    AddCategoryTab("Destaque")
    AddCategoryTab("Acessórios")
    AddCategoryTab("Cabelo")
    AddCategoryTab("Roupas")
    AddCategoryTab("Rostos")

    -- Itens pré-carregados (Mocks baseados na imagem para preencher a tela)
    local DefaultCatalogItems = {
        {Name = "Sung Jin Woo", Id = "11311090382", Price = 101},
        {Name = "Casaco Longo", Id = "12143431693", Price = 83},
        {Name = "Bengala Infantil", Id = "14343216900", Price = 67},
        {Name = "ez Capa", Id = "14234316933", Price = 38},
        {Name = "Agente Secreto Gato", Id = "14563431690", Price = 67},
        {Name = "Claymore", Id = "11234316120", Price = 35},
        {Name = "Lenço de Pescoço", Id = "11343216922", Price = 38},
        {Name = "Espada Netherite", Id = "14342316932", Price = 45},
        {Name = "Capa de Meme Gato", Id = "11343216899", Price = 38},
    }

    for _, item in ipairs(DefaultCatalogItems) do
        AddCatalogItem(item.Name, item.Id, item.Price)
    end

    -- Processa a entrada manual de IDs (Insira o Link do Item)
    local function EquipFromInput()
        local input = LinkInputBox.Text
        local numericId = tonumber(input:match("%d+")) -- Extrai apenas os números caso colem um link completo
        if numericId then
            task.spawn(function()
                local name = "Item Customizado"
                local success, info = pcall(function()
                    return MarketplaceService:GetProductInfo(numericId)
                end)
                if success and info then name = info.Name end
                
                selectedModalId = numericId
                currentModalAction = "Accessory"
                PTitle.Text = "EQUIPAR ITEM"
                PName.Text = name
                PApplyBtn.Text = "Equipar"
                PImage.Image = "rbxthumb://type=Asset&id=" .. numericId .. "&w=150&h=150"
                ModalOverlay.Visible = true
                PreviewBox.Visible = true
            end)
        else
            SendNotification("Insira um link ou ID válido.", 3)
        end
    end

    EquipLinkBtn.MouseButton1Click:Connect(EquipFromInput)
    LinkInputBox.FocusLost:Connect(function(enter) if enter then EquipFromInput() end end)

    -- Atualiza constantemente o clone no Viewport para refletir a aparência do jogador
    task.spawn(function()
        while task.wait(1) do
            if not CatalogGui.Parent then break end
            
            -- Limpa itens antigos do viewport
            for _, child in ipairs(Viewport:GetChildren()) do
                if child:IsA("Model") then child:Destroy() end
            end

            local originalChar = LocalPlayer.Character
            if originalChar then
                originalChar.Archivable = true
                local charClone = originalChar:Clone()
                charClone.Parent = Viewport
                
                -- Configura a câmera focar na cabeça/tronco do clone
                local hrp = charClone:FindFirstChild("HumanoidRootPart")
                if hrp then
                    vpCamera.CFrame = CFrame_new(hrp.Position + Vector3_new(0, 1.5, 5), hrp.Position + Vector3_new(0, 0.5, 0))
                end
                
                UpdateEquippedList()
            end
        end
    end)
end
